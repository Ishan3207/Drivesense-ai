# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai           # "openai" | "gemini"
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ── Google Maps ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/drivesense

# ── App Settings ───────────────────────────────────────────────────────────────
APP_ENV=development           # "development" | "production"
CORS_ORIGINS=*
DEFAULT_CURRENCY=USD
DEFAULT_REGION=United States
